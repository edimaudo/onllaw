{
  "functions": {
    "api/main.py": {
      
      "memory": 1024,
      "maxDuration": 60
    }
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/main.py"
    },
    {
      "source": "/(.*)",
      "destination": "api/main.py"
    }
  ]
}
